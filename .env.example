# Application name
VITE_APP_NAME=SoftSuave Hire

# Vite dev server proxy target — Node-side only, not sent to browser
# VITE_PROXY_TARGET=http://localhost:8000
VITE_PROXY_TARGET=

# Client-side API base URL (empty = relative URLs, proxy handles routing)
VITE_API_BASE_URL=

# WebSocket base URL (empty = derived from window.location at runtime)
VITE_WS_URL=

# LiveKit server URL (wss:// in production)
VITE_LIVEKIT_HOST=wss://your.livekit.server

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
