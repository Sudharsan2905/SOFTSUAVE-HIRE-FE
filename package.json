{
  "name": "softsuvehire-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "sonar": "sonar-scanner",
    "quality": "npm run coverage && npm run sonar"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --check"
    ],
    "src/**/*.css": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@react-oauth/google": "^0.12.1",
    "@react-pdf/renderer": "^4.5.1",
    "@reduxjs/toolkit": "^2.3.0",
    "@uiw/react-md-editor": "^4.1.1",
    "axios": "^1.15.3",
    "date-fns": "^4.1.0",
    "devtools-detect": "^4.0.2",
    "livekit-client": "^2.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.27.0",
    "react-syntax-highlighter": "^16.1.1",
    "read-excel-file": "^9.0.10",
    "screenfull": "^6.0.2",
    "write-excel-file": "^4.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "sonarqube-scanner": "^4.2.3",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "axios": "^1.15.3"
  }
}
